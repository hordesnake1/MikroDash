# MikroDash production profile for R5S -> MikroTik hEX S
# Copy to deploy/r5s/.env and adjust values for your management subnet.

# MikroDash HTTP
PORT=3081
HISTORY_MINUTES=30
ROS_WRITE_TIMEOUT_MS=30000
MAX_SOCKETS=25

# Protect the dashboard even on an internal network.
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=change-this-now
# Set only when a reverse proxy sits in front of MikroDash.
TRUSTED_PROXY=

# RouterOS API target (your hEX S)
ROUTER_HOST=192.168.88.1
ROUTER_PORT=8728
ROUTER_TLS=false
ROUTER_TLS_INSECURE=false
ROUTER_USER=mikrodash
ROUTER_PASS=change-me
DEFAULT_IF=ether1

# Polling intervals (ms)
CONNS_POLL_MS=3000
KIDS_POLL_MS=3000
DHCP_POLL_MS=15000
LEASES_POLL_MS=15000
ARP_POLL_MS=30000
SYSTEM_POLL_MS=3000
WIRELESS_POLL_MS=5000
VPN_POLL_MS=10000
FIREWALL_POLL_MS=10000
IFSTATUS_POLL_MS=5000
PING_POLL_MS=10000

# Connectivity monitor target
PING_TARGET=1.1.1.1

# Top-N limits
TOP_N=5
TOP_TALKERS_N=5
FIREWALL_TOP_N=15
MAX_CONNS=20000
